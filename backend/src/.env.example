# Single Consolidated Database URL
# All TCC data (users, trips, agencies, facilities) in one database
DATABASE_URL="postgresql://user:password@localhost:5432/postgres"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-here"

# Server Configuration
PORT=5001
NODE_ENV="development"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Frontend URL (for email links)
FRONTEND_URL="http://localhost:3000"

# SMS Configuration (for future Twilio integration)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Google Maps API (for future integration)
GOOGLE_MAPS_API_KEY=""

# Epic FHIR Integration (Phase 2 - Sandbox)
# Store actual values in backend/.env or backend/.env.local - never commit secrets
# See docs/active/features/epic_credentials_setup.md for setup instructions
EPIC_CLIENT_ID=""
EPIC_CLIENT_SECRET=""
EPIC_FHIR_BASE_URL="https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4"
# Redirect URI must match Epic app config. For backend callback (recommended for Phase 2):
#   http://localhost:5001/api/epic/callback  (local) or https://tencomm.com/api/epic/callback (prod)
# For frontend callback (needs /auth/epic/callback page):
#   http://localhost:3000/auth/epic/callback
EPIC_REDIRECT_URI="http://localhost:5001/api/epic/callback"
